<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="styesheets" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-800">
    <div class="text-white">
        <a class="text-blue-500 m-5 text-xl block" href="/">Go back to home </a>
        <h1 class="text-2xl m-5">Update Users</h1>
        <div class="m-5 bg-zinc-700 w-96 p-6 rounded-lg">
            <form action="/update/<%=user._id%>" method="post" class="flex flex-col gap-4">
                <input class="bg-zinc-500 rounded-lg px-4 h-10 text-white" type="text" placeholder="Name"   name="name" value="<%=user.name%>">
                <input class="bg-zinc-500 rounded-lg px-4 h-10 text-white"type="email" placeholder="Email" name="email" value="<%=user.email%>">
                <input class="bg-zinc-500 rounded-lg px-4 h-10 text-white" type="text" placeholder="Image URL" name="image" value="<%=user.image%>">
                <input class="bg-blue-500 rounded-lg h-10 text-white cursor-pointer"   type="submit" value="Update User">
            </form>
        </div>
    </div>

</body>
</html>