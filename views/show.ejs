<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="styesheets" href="/public/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-800">
    <div class="text-white">
        <a class="text-blue-500 m-5 text-xl block" href="/">Go back to home</a>
        <h1 class="text-2xl m-5">All Users</h1>

        <div class="users flex">
            <% if(users.length>0){ %>
                <% users.forEach(function(users){ %>
                <div class=" user  bg-zinc-700 w-64 h-80 m-5 p-4 rounded-lg text-black">
                    <img class="h-48 w-56 bg-red-400 mb-2 " src="<%= users.image%>">
                    <h3 class=""><%= users.name%></h3>
                    <h5 class="mt-2"><%= users.email %></h5>
                    <div class="flex justify-between mt-3">
                        <a class=" text-zinc-500"  href="/edit/<%=users._id%>">Edit user</a>
                        <a class=" text-red-400"  href="/delete/<%=users._id%>">Delete user</a>
                    </div>
                </div>
                <% }) %>
            <% }else{ %>
                <h3 class=" m-5  text-zinc-500">No user yet</h3>
            <%}%>
            
        </div>
        
       
    </div>

</body>
</html>